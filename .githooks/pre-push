#!/usr/bin/env bash
# pre-push — blocks any push that would leak brand/PII/machine-path strings
# into the public blueprint repo. Wired via `git config core.hooksPath
# .githooks`. Delegates the actual scan to scripts/leak-check.sh.
set -euo pipefail

zero_sha="0000000000000000000000000000000000000000"

failed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip ref deletions (nothing being pushed).
  if [[ "$local_sha" == "$zero_sha" ]]; then
    continue
  fi

  # Release protocol wants annotated tags — warn (never block) on lightweight v* tags.
  if [[ "$remote_ref" == refs/tags/v* ]] && [[ "$(git cat-file -t "$local_sha")" == "commit" ]]; then
    echo "WARNING: ${remote_ref#refs/tags/} is a LIGHTWEIGHT tag — protocol wants annotated (git tag -a)" >&2
  fi

  if [[ "$remote_sha" == "$zero_sha" ]]; then
    old="$(git hash-object -t tree /dev/null)"
  else
    old="$remote_sha"
  fi

  repo_root="$(git rev-parse --show-toplevel)"
  if ! "$repo_root/scripts/leak-check.sh" --range "$old" "$local_sha"; then
    failed=1
  fi
done

if [[ "$failed" -ne 0 ]]; then
  echo "PUSH BLOCKED: leak-check failed — nothing was pushed" >&2
  exit 1
fi

exit 0
